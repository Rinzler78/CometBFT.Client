{
  "version": "0.2",
  "language": "en",
  "dictionaries": ["en_US", "en-gb"],
  "ignorePaths": [
    ".cspell.json",
    "coverage/**",
    "artifacts/**",
    ".worktrees/**",
    "**/*.lock",
    "**/packages.lock.json",
    "openspec/**",
    ".claude/**",
    "_bmad/**",
    "_bmad-output/**",
    ".agents/**",
    "design-artifacts/**",
    "**/obj/**",
    "**/bin/**",
    "TestResults/**",
    "**/*.g.cs",
    "**/*.generated.cs",
    "**/LegacyProto/**"
  ],
  "words": [
    "CometBFT", "cometbft",
    "Tendermint", "tendermint",
    "grpc", "gRPC", "Grpc",
    "protobuf", "proto",
    "Rinzler",
    "NuGet", "nuget",
    "dotnet",
    "csproj", "slnf",
    "Polly",
    "WireMock",
    "Coverlet",
    "NSubstitute",
    "xunit",
    "Spectre", "Renderable",
    "DocFX", "docfx",
    "OpenAPI", "swagger",
    "async", "await",
    "nullable", "readonly", "init",
    "testnet", "mainnet",
    "lcd", "rpc", "abci", "ABCI",
    "Osmosis", "osmosis",
    "Cosmos", "cosmos",
    "cosmoshub",
    "tendermintrpc",
    "dependabot", "gitflow", "editorconfig", "worktrees", "worktree",
    "snupkg", "nupkg",
    "cspell", "warnaserror", "analyzers",
    "cobertura", "lcov", "trx",
    "websocket", "WebSocket",
    "backoff", "jitter",
    "semver", "SemVer",
    "Unreleased",
    "ReportGenerator", "reportgenerator",
    "PooledConnectionLifetime",
    "blockchain", "Blockchain",
    "norestore", "nobuild", "nologo", "maxcpucount",
    "keepalive",
    "Lava", "lava",
    "kvstore",
    "Prevote",
    "uatom"
  ],
  "overrides": [
    {
      "filename": "**/*.cs",
      "words": ["Tx", "tx", "TxHash", "RawLog", "GasUsed", "GasWanted", "metas"]
    },
    {
      "filename": "tests/**/*.cs",
      "words": [
        "prms",
        "AABB", "AABBCC", "DDEEFF",
        "PREVHASH", "BLOCKHASH", "EVIDENCEHASH",
        "HASHASYNC", "HASHCOMMIT",
        "TXBYTES", "VALADDR", "AQID",
        "mykey", "myvalue", "mynode",
        "APPHASH"
      ]
    }
  ]
}
