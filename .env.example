# Environment template — copy to .env and fill in real values
# .env is git-ignored; never commit secrets.

# NuGet API key for publishing Rinzler78.CometBFT.Client
# Create at https://www.nuget.org/account/apikeys
# Scope: Push new packages and package versions
# Glob pattern: Rinzler78.CometBFT.Client*
NUGET_API_KEY=

# CometBFT testnet endpoints (defaults already set in scripts/test.sh)
# Override here to point at a different node during local development.
# COMETBFT_RPC_URL=https://cosmoshub.tendermintrpc.lava.build:443
# COMETBFT_WS_URL=wss://cosmoshub.tendermintrpc.lava.build:443/websocket
# COMETBFT_GRPC_URL=cosmoshub.grpc.lava.build
