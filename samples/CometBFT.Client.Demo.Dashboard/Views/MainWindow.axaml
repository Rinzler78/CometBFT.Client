<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CometBFT.Client.Demo.Dashboard.ViewModels"
        x:Class="CometBFT.Client.Demo.Dashboard.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="CometBFT Dashboard"
        Width="1200"
        Height="800"
        MinWidth="900"
        MinHeight="600">

    <DockPanel>
        <!-- Footer: connection status -->
        <Border DockPanel.Dock="Bottom"
                Background="#1e1e2e"
                Padding="8,4">
            <TextBlock Text="{Binding ConnectionStatus}" Foreground="#cdd6f4" FontSize="12" VerticalAlignment="Center" />
        </Border>

        <!-- Main 3-column layout -->
        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="260" />
            </Grid.ColumnDefinitions>

            <!-- ── Left column ── -->
            <DockPanel Grid.Column="0" Margin="0,0,8,0">
                <!-- Node info card -->
                <Border DockPanel.Dock="Top" Background="#1e1e2e" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Node" FontWeight="Bold" Foreground="#cba6f7" FontSize="13" />
                        <Separator />
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Text="Chain" Foreground="#888" FontSize="11" Grid.Column="0" />
                            <TextBlock Text="{Binding ChainId}" Foreground="#cdd6f4" FontSize="11" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Text="Moniker" Foreground="#888" FontSize="11" Grid.Column="0" />
                            <TextBlock Text="{Binding Moniker}" Foreground="#cdd6f4" FontSize="11" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Text="Node ID" Foreground="#888" FontSize="11" Grid.Column="0" />
                            <TextBlock Text="{Binding NodeId}" Foreground="#cdd6f4" FontSize="11" Grid.Column="1" TextTrimming="CharacterEllipsis" />
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Text="Version" Foreground="#888" FontSize="11" Grid.Column="0" />
                            <TextBlock Text="{Binding NodeVersion}" Foreground="#cdd6f4" FontSize="11" Grid.Column="1" />
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Text="Syncing" Foreground="#888" FontSize="11" Grid.Column="0" />
                            <TextBlock Text="{Binding IsSyncing}" Foreground="#cdd6f4" FontSize="11" Grid.Column="1" />
                        </Grid>
                        <Grid ColumnDefinitions="80,*">
                            <TextBlock Text="Peers" Foreground="#888" FontSize="11" Grid.Column="0" />
                            <TextBlock Text="{Binding PeerCount}" Foreground="#cdd6f4" FontSize="11" Grid.Column="1" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Validators — x:CompileBindings="False" because DataGridTextColumn row type is runtime -->
                <Border Background="#1e1e2e" CornerRadius="6" Padding="12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Validators" FontWeight="Bold" Foreground="#cba6f7" FontSize="13" Margin="0,0,0,4" />
                        <DataGrid x:CompileBindings="False"
                                  ItemsSource="{Binding Validators}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserReorderColumns="False"
                                  FontSize="11"
                                  Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*" />
                                <DataGridTextColumn Header="Power" Binding="{Binding VotingPower}" Width="70" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- ── Center column ── -->
            <DockPanel Grid.Column="1" Margin="0,0,8,0">
                <!-- Block header card -->
                <Border DockPanel.Dock="Top" Background="#1e1e2e" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Block" FontWeight="Bold" Foreground="#cba6f7" FontSize="13" />
                            <TextBlock Text="{Binding LatestHeight, StringFormat='#{0}'}" Foreground="#a6e3a1" FontWeight="Bold" FontSize="13" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding LatestBlockTime}" Foreground="#888" FontSize="11" />
                            <TextBlock Text="{Binding LatestBlockTxCount, StringFormat='{}{0} txs'}" Foreground="#fab387" FontSize="11" />
                            <TextBlock Text="{Binding PendingTxCount, StringFormat='mempool: {0}'}" Foreground="#89dceb" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Block feed -->
                <Border DockPanel.Dock="Top" Background="#1e1e2e" CornerRadius="6" Padding="12" Height="240" Margin="0,0,0,8">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Recent Blocks" FontWeight="Bold" Foreground="#cba6f7" FontSize="13" Margin="0,0,0,4" />
                        <ListBox ItemsSource="{Binding Blocks}" Background="Transparent" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:BlockRow">
                                    <Grid ColumnDefinitions="70,110,50,*">
                                        <TextBlock Text="{Binding Height, StringFormat='#{0}'}" Foreground="#a6e3a1" Grid.Column="0" />
                                        <TextBlock Text="{Binding Time}" Foreground="#888" Grid.Column="1" />
                                        <TextBlock Text="{Binding TxCount, StringFormat='{}{0} txs'}" Foreground="#fab387" Grid.Column="2" />
                                        <TextBlock Text="{Binding Proposer}" Foreground="#89b4fa" Grid.Column="3" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- Transaction feed -->
                <Border Background="#1e1e2e" CornerRadius="6" Padding="12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Recent Transactions" FontWeight="Bold" Foreground="#cba6f7" FontSize="13" Margin="0,0,0,4" />
                        <ListBox ItemsSource="{Binding Transactions}" Background="Transparent" FontSize="11">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:TxRow">
                                    <Grid ColumnDefinitions="*,70,60,*">
                                        <TextBlock Text="{Binding Hash}" Foreground="#89b4fa" Grid.Column="0" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Height, StringFormat='h={0}'}" Foreground="#888" Grid.Column="1" />
                                        <TextBlock Text="{Binding Code, StringFormat='code={0}'}" Foreground="#fab387" Grid.Column="2" />
                                        <TextBlock Text="{Binding Log}" Foreground="#888" Grid.Column="3" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </DockPanel>

            <!-- ── Right column: event log ── -->
            <Border Grid.Column="2" Background="#1e1e2e" CornerRadius="6" Padding="12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Event Log" FontWeight="Bold" Foreground="#cba6f7" FontSize="13" Margin="0,0,0,4" />
                    <ListBox ItemsSource="{Binding EventLog}" Background="Transparent" FontSize="10">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:EventLogRow">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Timestamp}" Foreground="#888" />
                                    <TextBlock Text="{Binding Description}" Foreground="#cdd6f4" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
